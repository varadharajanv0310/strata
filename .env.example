# ============================================================
# strata backend — environment configuration
# Copy to `.env` and fill in. Every value has a safe local default;
# secrets are optional and connectors skip+flag when their key is absent.
# ============================================================

# ---- core ----
STRATA_ENV=local                       # local | production
STRATA_LOG_LEVEL=INFO

# ---- serving / application database ----
# Local default is SQLite (no install needed). For production set this to a
# Postgres URL, e.g. postgresql+psycopg://strata:strata@localhost:5432/strata
DATABASE_URL=sqlite:///backend/data/app.db

# ---- analytical warehouse (DuckDB + Parquet, embedded) ----
DUCKDB_PATH=backend/data/warehouse.duckdb
DATA_DIR=backend/data                  # raw/, staging/, warehouse/ live under here

# ---- API ----
API_HOST=127.0.0.1
API_PORT=8000
# Comma-separated allowed origins for the frontend dev/prod servers
CORS_ORIGINS=http://localhost:5173,http://localhost:5191,http://127.0.0.1:5173

# ---- auth ----
JWT_SECRET=change-me-in-production-please
JWT_ALG=HS256
JWT_EXPIRE_MINUTES=10080                # 7 days

# ---- pipeline tunables (defensible defaults; see BUILD_LOG) ----
ROLE_VOLUME_FLOOR=200                   # min postings for a role cluster to enter the catalog (per country/period)
JOBSCORE_W_DEMAND=0.42                  # Job Score weights (normalized within country, then weighted sum)
JOBSCORE_W_INTEREST=0.25               # applied to INVERSE interest (less crowding = higher)
JOBSCORE_W_SALARY=0.33
FORECAST_HORIZON_MONTHS=12             # 6–12 month demand forecast
FORECAST_BACKTEST_PERIODS=6            # held-out periods for back-testing

# ---- Common Crawl scan scope (idempotent/resumable) ----
CC_RECENT_CRAWLS=3                      # number of most-recent monthly crawls
CC_HISTORICAL_YEARS=4                   # sample crawls back this many years for the time dimension
CC_INDEX_SERVER=https://index.commoncrawl.org
CC_TARGET_DOMAINS=                      # optional comma list of job-board/careers domains; blank = curated default set

# ---- data-source credentials (OPTIONAL — connectors skip+flag if absent) ----
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
LIGHTCAST_CLIENT_ID=
LIGHTCAST_CLIENT_SECRET=
# Aggregator + official sources with an OPTIONAL key (connectors skip+flag when absent):
BLS_API_KEY=                           # data.bls.gov — lifts the OEWS/baselines rate limit
HF_TOKEN=                              # huggingface.co — rate-limit headroom for the HF connector
USAJOBS_API_KEY=                       # developer.usajobs.gov — US federal role pay bands
USAJOBS_EMAIL=                         # the email registered with your USAJOBS API key
CEDEFOP_OVATE_URL=                     # Cedefop Skills-OVATE open-data URL (EU skill demand)
# Stack Overflow survey, GH Archive, Stack Exchange dump, O*NET, ESCO, OECD/World Bank PPP,
# ONS/Eurostat/MOM/JobBank/PLFS, ai-jobs.net — public downloads, no key required.

# ---- GPU / ML (only needed for the ml/ pipeline; see requirements-ml.txt) ----
ML_DEVICE=cuda                         # cuda | cpu
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_BATCH_SIZE=256
ML_VRAM_BUDGET_GB=16

# ---- LLM corpus-extraction backend (roles-only posting extraction) ----
LLM_BACKEND=auto                       # auto | vllm | ollama  (native Windows uses ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:8b                  # extractor (grammar-constrained JSON, roles-only schema)
OLLAMA_JUDGE_MODEL=gpt-oss:20b         # stronger model for extraction validation
